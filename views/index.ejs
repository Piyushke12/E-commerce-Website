<!DOCTYPE html>
<html>

<head>
  <title><%=title%></title>
  <link rel='stylesheet' href='/stylesheets/style.css' />
  <!-- Bootstrap core CSS -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.5.0/css/bootstrap.min.css" rel="stylesheet">
  <!-- Material Design Bootstrap -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/mdbootstrap/4.19.1/css/mdb.min.css" rel="stylesheet">

  <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
  <!-- Bootstrap tooltips -->
  <script type="text/javascript"
    src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.4/umd/popper.min.js"></script>
  <!-- Bootstrap core JavaScript -->
  <script type="text/javascript"
    src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/4.5.0/js/bootstrap.min.js"></script>
  <!-- MDB core JavaScript -->
  <script type="text/javascript" src="https://cdnjs.cloudflare.com/ajax/libs/mdbootstrap/4.19.1/js/mdb.min.js"></script>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <a class="navbar-brand" href="/"><svg class="bi bi-cart-check" width="3em" height="2em" viewBox="0 0 16 16"
        fill="currentColor" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd"
          d="M11.354 5.646a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L8 8.293l2.646-2.647a.5.5 0 0 1 .708 0z" />
        <path fill-rule="evenodd"
          d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm7 0a1 1 0 1 0 0 2 1 1 0 0 0 0-2z" />
      </svg></a>
    <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <ul class="navbar-nav mr-2 w-100">
        <li class="nav-item active">
          <a class="nav-link" href="/">Home <span class="sr-only">(current)</span></a>
        </li>
        <li class="nav-item active">
          <a class="nav-link" href="/shopping-cart">Shopping Cart
            <% if(session.cart != undefined && session.cart.totalQty > 0){ %>
            <span class="badge badge-dark badge-pill"><%= session.cart.totalQty %></span>
            <% } %>
          </a>
        </li>
        <li class="nav-item dropdown active">
          <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown"
            aria-haspopup="true" aria-expanded="false">
            User Management
          </a>
          <% if(login) {%>
          <div class="dropdown-menu" aria-labelledby="navbarDropdown">
            <a class="dropdown-item" href="/user/profile">User Account</a>
            <a class="dropdown-item" href="/user/logout">Logout</a>
          </div>
          <%} else {%>
          <div class="dropdown-menu" aria-labelledby="navbarDropdown">
            <a class="dropdown-item" href="/user/login">Log In</a>
            <a class="dropdown-item" href="/user/signup">Sign Up</a>
          </div>
          <%}%>
          </li>
        </ul>
        <form action="/search" method="POST" class="form-inline my-2 my-lg-0 ml-5 w-100">
          <input class="form-control w-75" type="search" placeholder="Search" name="search" aria-label="Search">
          <button class="btn btn-outline-primary my-2 my-sm-0" type="submit">Search</button>
        </form>
      </div>
    </nav>


    <!-- Ads -->
    <div id="carouselExampleIndicators" class="carousel slide m-1" data-ride="carousel" style="width:100%;height:250px;">
      <ol class="carousel-indicators">
        <li data-target="#carouselExampleIndicators" data-slide-to="0" class="active"></li>
        <li data-target="#carouselExampleIndicators" data-slide-to="1"></li>
        <li data-target="#carouselExampleIndicators" data-slide-to="2"></li>
      </ol>
      <div class="carousel-inner">
        <div class="carousel-item">
          <img class="d-block w-100" src="https://cdn.static-zoutons.com/images/originals/blog/flipkart_electronics_and_accessories_1579174521.JPG"
          class="img-responsive middle mt-2" alt="First slide" style="width:100%;height:250px;" alt="Second slide">
        </div>
        <div class="carousel-item">
          <img class="d-block w-100" src="https://t4.ftcdn.net/jpg/01/94/50/19/240_F_194501965_XCZYcx3XD2iTYEUfqbRCFOQuiDA7IX3g.jpg"
          class="img-responsive middle mt-2" alt="First slide" style="width:100%;height:250px;" alt="First slide">
        </div>
        <div class="carousel-item active">
          <img class="d-block w-100" src="https://rukminim1.flixcart.com/flap/1800/1800/image/899168ed3e4a581f.jpg?q=80"
          class="img-responsive middle mt-2" alt="First slide" style="width:100%;height:250px;" alt="Third slide">
        </div>
      </div>
      <a class="carousel-control-prev" href="#carouselExampleIndicators" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Previous</span>
      </a>
      <a class="carousel-control-next" href="#carouselExampleIndicators" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Next</span>
      </a>

    <% if(popup.length > 0) {%>
          <div class="alert alrt-success">
            <%= popup %>
          </div>
          <% } %>

          <!-- Products -->
          <% products.forEach(function(product){ %>
          <div class="row w-100 ml-1 ">
            <% product.forEach(function(item){ %>
              <div class="card m-3 h-50" style="width: 18rem;">
                <img class="card-img-top h-25" src="<%= item.imagePath %>" alt="Card image cap">
                <div class="card-body">
                  <h5 class="card-title"><%= item.title %></h5>
                  <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                </div>
                <ul class="list-group list-group-flush">
                  <li class="list-group-item"><%= item.brand %></li>
                  <li class="list-group-item"><%= item.description %></li>
                </ul>
                <div class="card-body">
                  <a href="#price" class="card-link"> ₹<%= item.price %></a>
                  <a href="/add-to-cart/<%= item.id %>" class="card-link">Add to Cart</a>
                </div>
              </div>
            <!-- <div class="d-flex flex-column col-sm-4 w-100">
              <div class="card mt-3 justify-content-center text-center">
                <div class="caption ml-2">
                  <img src="<%= item.imagePath %>"
                    class="img-responsive middle mt-2 mb-1" alt="..." style="width:120px;height:120px">
                  <h5><%= item.title %></h5>
                  <h6 class="description m-2"><%= item.brand %></h6>
                  <h6 class="description m-2"><%= item.description %></h6>
                </div>
                <div class="d-flex mb-2">
                  <div class="badge badge-dark badge-pill text-success pt-2 m-3 ml-5 mr-5"
                    style="width:6rem; height:28px;">
                    $<%= item.price %></div>
                  <a href="/add-to-cart/<%= item.id %>" class="productbtn" role="button">Add to Cart</a>
                </div>
              </div>
            </div> -->
            <% }) %>
          </div>
          <% }) %>

<!-- Footer -->
<footer class="page-footer font-small indigo mt-1">

  <!-- Footer Links -->
  <div class="container">

    <!-- Grid row-->
    <hr class="rgba-white-light" style="margin: 0 15%;">

    <!-- Grid row-->
    <div class="row d-flex text-center justify-content-center mb-md-0 mb-4">

      <!-- Grid column -->
      <div class="col-md-8 col-12 mt-5">
        <p style="line-height: 1.7rem">
          Lorem Text is best, following adipiscing elit.
          The Great, accepted of him to attain unto this age, and praise with canticles,
           by the law to carry messages, betake himself more fun than a greater number.
           </div>
      <!-- Grid column -->

    </div>
    <!-- Grid row-->
    <hr class="clearfix d-md-none rgba-white-light" style="margin: 10% 15% 5%;">

    <!-- Grid row-->
    <div class="row pb-3">

      <!-- Grid column -->
      <div class="col-md-12">

        <div class="mb-5 flex-center">

          <!-- Facebook -->
          <a class="fb-ic">
            <i class="fab fa-facebook-f fa-lg white-text mr-4"> </i>
          </a>
          <!-- Twitter -->
          <a class="tw-ic">
            <i class="fab fa-twitter fa-lg white-text mr-4"> </i>
          </a>
          <!-- Google +-->
          <a class="gplus-ic">
            <i class="fab fa-google-plus-g fa-lg white-text mr-4"> </i>
          </a>
          <!--Linkedin -->
          <a class="li-ic">
            <i class="fab fa-linkedin-in fa-lg white-text mr-4"> </i>
          </a>
          <!--Instagram-->
          <a class="ins-ic">
            <i class="fab fa-instagram fa-lg white-text mr-4"> </i>
          </a>
          <!--Pinterest-->
          <a class="pin-ic">
            <i class="fab fa-pinterest fa-lg white-text"> </i>
          </a>

        </div>

      </div>
      <!-- Grid column -->

    </div>
    <!-- Grid row-->

  </div>
  <!-- Footer Links -->

  <!-- Copyright -->
  <div class="footer-copyright text-center py-3">© 2020 Copyright:
    <a href="https://mdbootstrap.com/"> ClicknBuy.com</a>
  </div>
  <!-- Copyright -->

</footer>
<!-- Footer -->
</body>
</html>